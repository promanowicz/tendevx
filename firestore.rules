rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Campaigns
    // Public read so client apps can fetch campaigns without authenticating.
    // Writes are restricted to the campaign owner (commercial manager users).
    match /campaigns/{campaignId} {
      allow read: if resource.data.get('isDeleted', false) != true;

      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;
    }

    // Users
    // Each user can only read and write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Groups — reserved for future use
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
